# Optional LLM settings
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest
DOUBAO_API_KEY=
DOUBAO_MODEL=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Pipeline settings
TIMEZONE=Asia/Shanghai
DAILY_LIMIT=10
MIN_SCORE=0.10
DEDUPE_DAYS=7
DB_PATH=data/papers.db
OUTPUT_DIR=outputs/daily
XMIND_DIR=outputs/xmind
LOG_DIR=logs

# Source toggles
ENABLE_ARXIV=1
ENABLE_SEMANTIC_SCHOLAR=1
ENABLE_HUGGINGFACE=1
ENABLE_PAPERSWITHCODE=1
ENABLE_ACL=1
ENABLE_OPENREVIEW=0
SEMANTIC_SCHOLAR_API_KEY=

# macOS desktop notification title
NOTIFY_TITLE=AI Paper Daily
DASHBOARD_URL=http://127.0.0.1:8000

# Optional: use Postgres in deployment
DATABASE_URL=
